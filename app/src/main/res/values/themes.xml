<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.WakeyWakeyLAN" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_500</item>
        <item name="colorPrimaryVariant">@color/brand_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_500</item>
        <item name="colorSecondaryVariant">@color/accent_300</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/brand_900</item>
        <item name="colorSurface">@color/surface_900</item>
        <item name="colorOnSurface">@color/text_100</item>
        <item name="android:statusBarColor">@color/brand_900</item>
        <item name="android:navigationBarColor">@color/brand_900</item>
    </style>

    <style name="Theme.WakeyWakeyLAN.NoDisplay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>